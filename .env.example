# ─────────────────────────────────────────
# Database (Supabase or any PostgreSQL)
# ─────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/melodix?schema=public"

# ─────────────────────────────────────────
# Auth.js (NextAuth v5)
# ─────────────────────────────────────────
AUTH_SECRET="your-secret-here"   # openssl rand -base64 32
AUTH_URL="http://localhost:3000"

# Kakao OAuth
AUTH_KAKAO_ID=""
AUTH_KAKAO_SECRET=""

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Apple OAuth
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# ─────────────────────────────────────────
# AWS S3 (이미지 업로드)
# ─────────────────────────────────────────
AWS_REGION="ap-northeast-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="melodix-uploads"
AWS_CLOUDFRONT_URL="https://your-distribution.cloudfront.net"

# ─────────────────────────────────────────
# 토스페이먼츠
# ─────────────────────────────────────────
TOSS_CLIENT_KEY=""
TOSS_SECRET_KEY=""
TOSS_WEBHOOK_SECRET=""

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="악기놀이터"
